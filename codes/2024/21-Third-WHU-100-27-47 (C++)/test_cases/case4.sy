/* IR for reference:

Function    √√√
Register    √√/
BasicBlock  √√√
Variable    √√/
Address     √√/
Operand     √√/
OperStmt    √√
CallStmt    √√
RetStmt     √√
LoadStmt    √√
StoreStmt   √√
AllocStmt   √√
PhiStmt     √√
BrStmt      √√

@w = global i32 0           ; GlobalVar

define i32 @f(i32 %x) {     ; Function(Register)
entry:                      ; - BasicBlock
  %x = add i32 %x, 1        ; - - OperStmt
  ret i32 %x                ; - - RetStmt
}

define void @g(i32 %x) {    ; Function(Register)
entry:                      ; - BasicBlock
  %t = load i32 0(@w)       ; - - LoadStmt
  %s = alloc [10 x i32]     ; - - AllocStmt
  store i32 1, 0(%s)        ; - - StoreStmt
  store i32 2, 1(%s)        ; - - StoreStmt
  %1 = load i32 0(%s)       ; - - LoadStmt
  %2 = call i32 @f(i32 %1)  ; - - CallStmt
  store i32 %2, 0(@w)       ; - - StoreStmt
  ret void                  ; - - RetStmt
}

define i32 @foo() {         ; Function()
entry:                      ; - BasicBlock
  %a = add i32 0, 1         ; - - OperStmt
  %b = add i32 0, 2         ; - - OperStmt
  %1 = add i32 %a, %b       ; - - OperStmt
  %2 = add i32 %1, 3        ; - - OperStmt
  %a = add i32 %2, 1        ; - - OperStmt
  %3 = cast f32 i32 %a      ; - - CastStmt
  %d = add f32 %3, 0F       ; - - OperStmt
  ret i32 %d                ; - - RetStmt
}

