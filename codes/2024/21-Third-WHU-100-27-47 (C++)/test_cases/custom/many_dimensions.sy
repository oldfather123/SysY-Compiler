// #include <iostream>
int array_sum_6d(int arr[2][2][2][2][2][2], int x1, int x2, int x3, int x4, int x5, int x6) {
    int sum;
    int idx1, idx2, idx3, idx4, idx5, idx6;

    sum = 0;
    idx1 = 0;

    while (idx1 < x1) {
        idx2 = 0;
        while (idx2 < x2) {
            idx3 = 0;
            while (idx3 < x3) {
                idx4 = 0;
                while (idx4 < x4) {
                    idx5 = 0;
                    while (idx5 < x5) {
                        idx6 = 0;
                        while (idx6 < x6) {
                            sum = sum + arr[idx1][idx2][idx3][idx4][idx5][idx6];
                            idx6 = idx6 + 1;
                        }
                        idx5 = idx5 + 1;
                    }
                    idx4 = idx4 + 1;
                }
                idx3 = idx3 + 1;
            }
            idx2 = idx2 + 1;
        }
        idx1 = idx1 + 1;
    }

    return sum;
}

int main() {
    int arr[2][2][2][2][2][2];
    int result;

    // 初始化六维数组，数组长度为2^6 = 64
    int idx1 = 0;
    int idx2, idx3, idx4, idx5, idx6;
    int value = 1;

    while (idx1 < 2) {
        idx2 = 0;
        while (idx2 < 2) {
            idx3 = 0;
            while (idx3 < 2) {
                idx4 = 0;
                while (idx4 < 2) {
                    idx5 = 0;
                    while (idx5 < 2) {
                        idx6 = 0;
                        while (idx6 < 2) {
                            arr[idx1][idx2][idx3][idx4][idx5][idx6] = value;
                            value = value + 1;
                            idx6 = idx6 + 1;
                        }
                        idx5 = idx5 + 1;
                    }
                    idx4 = idx4 + 1;
                }
                idx3 = idx3 + 1;
            }
            idx2 = idx2 + 1;
        }
        idx1 = idx1 + 1;
    }

    // 计算六维数组元素的总和
    result = array_sum_6d(arr, 2, 2, 2, 2, 2, 2);

    // std::cout << result << std::endl;
    putint(result);
    
    return 0; // 期望返回 2080 (1 + 2 + ... + 64)
}
