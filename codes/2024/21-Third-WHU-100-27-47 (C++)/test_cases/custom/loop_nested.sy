int main() {
    int a[5][5][5] = {};
    int i, j, k;
    i = 0;
    while (i - 10 < -5) {
        j = 0;
        while (j - 10 < -5) {
            k = 0;
            while (k - 10 < -5) {
                a[i][j][k] = i + j + k;
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    i = 0;
    while (i - 10 < -5) {
        j = 0;
        while (j - 10 < -5) {
            k = 0;
            while (k - 10 < -5) {
                putint(a[i][j][k]);
                putch(32);
                k = k + 1;
            }
            putch(10);
            j = j + 1;
        }
        putch(10);
        i = i + 1;
    }
    return 0;
}
