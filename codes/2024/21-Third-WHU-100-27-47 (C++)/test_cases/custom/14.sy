int val = -5;
int arr[10][10]={{1,2,3},{},{4,5,6,7}};

int g(int a, int b, int c) {
    int x1=a+b+c,x2=a-b+c,x3=a+b-c,x4=a-b-c,x5=a*b*c;
    return a + b + c + x1+x2+x3+x4+x5;
}

int f(int a) {
    int b = a*a;
    val = b;
    g(-3, a, a);
    return a+b+arr[2][1];
}

int main() {
    return f(3);
}
