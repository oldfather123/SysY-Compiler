int exgcd(int a,int b) {
	int c = a*b;
	int i = 0;
	int j = i + 1;
	int k = j*2;
	while(i<c){
		i = i - 1;
		j = 2 * i;
		k = j * 5;

	}
	c = c - j;
	c = c - k;
	return c;
} 

int main() {
	int a = 1;
	int b = exgcd(a,5);
	while(a>b){
		if(a == 1){
			break;
		}
		a = a - 1;
	}
	return b;
}