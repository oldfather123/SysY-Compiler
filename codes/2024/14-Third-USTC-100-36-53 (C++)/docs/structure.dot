digraph llvm_transformation {
    bgcolor= transparent;
    compound=true; // 允许跨子图的边
    node [shape=box];
    rankdir=LR; 
    newrank=true; // 使用新的排列引擎

        label="compiler structure";

        SysyNew [label="Sysy", shape=ellipse];
        FrontEndNew [label="FrontEnd"];
        LLVM_IRNew [label="LLVM IR", shape=ellipse];
        PassesManager [label="passes manager"];
        AnalysisPass [label="analysis pass", shape=ellipse];
        TransformPass  [label="transform pass", shape=ellipse];
        InstructionSelection [label="Instruction\n Selection"];
        MIR [label="MIR", shape=ellipse];
        MIROpt [label="Machine IR optimazation"];
        CodeEmission [label="Register Allocation"];
        TargetCodeNew [label="RISCV asm", shape=ellipse, style=filled, fillcolor="#FFB6C1"];

        SysyNew -> FrontEndNew;
        FrontEndNew -> LLVM_IRNew;
        LLVM_IRNew -> PassesManager;
        PassesManager -> LLVM_IRNew;
        PassesManager -> AnalysisPass;
        PassesManager -> TransformPass;
        LLVM_IRNew -> InstructionSelection;
        InstructionSelection -> MIR;
        MIR -> MIROpt
        MIROpt -> MIR;
        MIR -> CodeEmission;
        CodeEmission -> TargetCodeNew;
    



    {rank=same; SysyNew; FrontEndNew; LLVM_IRNew; InstructionSelection; MIR; CodeEmission; TargetCodeNew;}
}
