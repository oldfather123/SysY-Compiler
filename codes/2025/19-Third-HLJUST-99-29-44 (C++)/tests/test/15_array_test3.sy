int a[5][5]={1,2,3,4,5};

int func(int a[][5]){
    int i=0;
    int j=0;
    int sum=0;
    while(i<5){
        while(j<5){
            sum=sum+a[i][j];
            j=j+1;
        }
        i=i+1;
    }
    return sum;
}

int main(){
    print(func(a));
    return 0;
}

// expected result: 15