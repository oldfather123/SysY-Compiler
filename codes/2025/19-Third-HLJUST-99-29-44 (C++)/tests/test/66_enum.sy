int main()
{
    int i;
    int j;
    int k;
    int t;
    i=0;j=0;k=0;
    while(i<21)
    {
        while(j<101-i)
        {
            k=100-i-j;
            if(5*i+1*j+k/2==100)
            {
                print(i);
                print(j);
                print(k);
            }
            j=j+1;
        }
        i=i+1;
    }

    return 0;
}

// expected result: 0 100 0