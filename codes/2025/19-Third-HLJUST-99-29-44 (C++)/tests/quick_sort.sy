int partition(int arr[], int low, int high) {
    int pivot = arr[high];
    int i = low - 1;
    int j=low;
    while( j <= high-1) {
        if(arr[j] < pivot) {
            i = i + 1;
            int tmp = arr[i];
            arr[i] = arr[j];
            arr[j] = tmp;
        } 
        j = j + 1;
    }
    
    int tmp = arr[i+1];
    arr[i+1] = arr[high];
    arr[high] = tmp;
    
    return i+1;
}

void quick_sort(int arr[], int low, int high) {
    if(low < high) {
        int pi = partition(arr, low, high);
        quick_sort(arr, low, pi - 1);
        quick_sort(arr, pi+1, high);
    }
}

int main() {
    int arr[10];
    getarray(arr);
    putarray(10, arr);
    quick_sort(arr, 0, 9);
    putarray(10, arr);
    
    return 0;
}
