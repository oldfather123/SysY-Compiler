;;===============================================
;; 低级内存操作
;;===============================================

(decl stack_addr (StackSlot) Inst)
(extractor
    (stack_addr slot)
    (inst_data_value (InstructionData.StackAddr slot))
)

(decl global_addr (Global) Inst)
(extractor
    (global_addr global)
    (inst_data_value (InstructionData.GlobalAddr global))
)

(decl load (Value Offset Type Value) Inst)
(extractor
    (load addr offset ty token)
    (inst_data_value (InstructionData.Load addr offset ty token))
)

(decl store (Value Offset Value Type Value) Inst)
(extractor
    (store addr offset value ty token)
    (inst_data_value (InstructionData.Store addr offset value ty token))
)

;;===============================================
;; 终结指令
;;===============================================

(decl jump (BlockCall) Inst) 
(extractor
    (jump block_call)
    (inst_data_value (InstructionData.Jump block_call))
)

(decl br_table (Value JumpTable) Inst)
(extractor
    (br_table idx JT)
    (inst_data_value (InstructionData.BranchTable idx JT))
)

(decl brif (Value BlockCall BlockCall) Inst)
(extractor
    (brif c block_then block_else)
    (inst_data_value (InstructionData.Brif c (block_call_2 block_then block_else)))
)

(decl return_call (FuncRef ValueVec) Inst)
(extractor
    (return_call func args)
    (inst_data_value (InstructionData.ReturnCall func args))
)

(decl return (ValueVec) Inst)
(extractor
    (return returns)
    (inst_data_value (InstructionData.Return returns))
)

(decl unreachable () Inst)
(extractor
    (unreachable)
    (inst_data_value (InstructionData.Unreachable))
) 

