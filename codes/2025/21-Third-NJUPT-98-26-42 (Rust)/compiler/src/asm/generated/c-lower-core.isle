        (y_reg XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Xor tmp x_reg y_reg)))
        (_ Unit (emit (MInst.Snez dst tmp))))
    (InstOutput.OutputReg dst)))

;; 浮点不等比较
(rule 1 (lower (has_type (ty_f32 ty) (ne x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.FeqS tmp x_reg y_reg)))
