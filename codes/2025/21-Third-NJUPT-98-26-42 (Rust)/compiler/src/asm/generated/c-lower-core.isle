(rule 0 (lower (has_type (ty_f64 ty) (le x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (_ Unit (emit (MInst.FleD dst x_reg y_reg))))
    (InstOutput.OutputReg dst)))

;; gt - 大于比较 (x > y) == (y < x)
(rule 3 (lower (has_type (and (ty_fit_xreg) (ty_fit_signed)) (gt x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg XReg (x_operand x))
        (y_reg XReg (x_operand y))
        (_ Unit (emit (MInst.Slt dst y_reg x_reg))))
    (InstOutput.OutputReg dst)))

(rule 2 (lower (has_type (and (ty_fit_xreg) (ty_fit_unsigned)) (gt x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg XReg (x_operand x))
        (y_reg XReg (x_operand y))
        (_ Unit (emit (MInst.Sltu dst y_reg x_reg))))
    (InstOutput.OutputReg dst)))

;; 浮点大于比较
(rule 1 (lower (has_type (ty_f32 ty) (gt x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (_ Unit (emit (MInst.FltS dst y_reg x_reg))))
