;; 浮点大于等于比较
(rule 1 (lower (has_type (ty_f32 ty) (ge x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (_ Unit (emit (MInst.FleS dst y_reg x_reg))))
