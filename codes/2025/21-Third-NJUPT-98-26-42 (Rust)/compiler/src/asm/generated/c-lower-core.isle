(rule 0 (lower (has_type (ty_f64 ty) (ne x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.FeqD tmp x_reg y_reg)))
        (_ Unit (emit (MInst.Seqz dst tmp))))
    (InstOutput.OutputReg dst)))

;; lt - 小于比较
(rule 3 (lower (has_type (and (ty_fit_xreg) (ty_fit_signed)) (lt x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg XReg (x_operand x))
