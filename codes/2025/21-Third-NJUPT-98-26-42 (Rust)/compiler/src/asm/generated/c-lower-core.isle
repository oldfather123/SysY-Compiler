(rule 0 (lower (has_type (ty_f64 ty) (gt x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (_ Unit (emit (MInst.FltD dst y_reg x_reg))))
    (InstOutput.OutputReg dst)))

;; ge - 大于等于比较 (x >= y) == !(x < y)
(rule 3 (lower (has_type (and (ty_fit_xreg) (ty_fit_signed)) (ge x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg XReg (x_operand x))
        (y_reg XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Slt tmp x_reg y_reg)))
