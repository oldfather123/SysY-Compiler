(rule 0 (lower (has_type (ty_f64 ty) (eq x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (_ Unit (emit (MInst.FeqD dst x_reg y_reg))))
