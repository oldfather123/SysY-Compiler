(rule 2 (lower (has_type (and (ty_fit_xreg) (ty_fit_unsigned)) (le x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg XReg (x_operand x))
        (y_reg XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Sltu tmp y_reg x_reg)))
