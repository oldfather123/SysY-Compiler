;;;; Rules for comparison operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; eq - 相等比较
(rule 2 (lower (has_type (ty_fit_xreg) (eq x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg XReg (x_operand x))
        (y_reg XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Xor tmp x_reg y_reg)))
        (_ Unit (emit (MInst.Seqz dst tmp))))
    (InstOutput.OutputReg dst)))

;; 浮点相等比较
(rule 1 (lower (has_type (ty_f32 ty) (eq x y)))
    (let (
        (dst XReg (xreg_new))
        (x_reg FReg (f_operand x))
        (y_reg FReg (f_operand y))
        (_ Unit (emit (MInst.FeqS dst x_reg y_reg))))
