    (InstOutput.OutputReg dst)))

;;;; Rules for unary operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; ineg - 整数取负
(rule 0 (lower (has_type (ty_i64 ty) (ineg val)))
    (let (
        (dst XReg (xreg_new))
        (val_reg XReg (x_operand val))
        (zero XReg (zero_reg))
        (_ Unit (emit (MInst.Sub dst zero val_reg))))
    (InstOutput.OutputReg dst)))

(rule 1 (lower (has_type (ty_i32 ty) (ineg val)))
    (let (
        (dst XReg (xreg_new))
        (val_reg XReg (x_operand val))
        (zero XReg (zero_reg))
        (_ Unit (emit (MInst.Subw dst zero val_reg))))
    (InstOutput.OutputReg dst)))

;; bnot - 位取反 (xor with -1)
(rule (lower (has_type (ty_fit_xreg) (bnot val)))
    (let (
        (dst XReg (xreg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.Xori dst val_reg $Imm12_MinusOne))))
    (InstOutput.OutputReg dst)))

;; fneg - 浮点取负
(rule 0 (lower (has_type (ty_f32 ty) (fneg val)))
    (let (
        (dst FReg (freg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FnegS dst val_reg))))
    (InstOutput.OutputReg dst)))

(rule 1 (lower (has_type (ty_f64 ty) (fneg val)))
    (let (
        (dst FReg (freg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FnegD dst val_reg))))
    (InstOutput.OutputReg dst)))

;; lnot - 逻辑非 (seqz)
(rule (lower (has_type (ty_fit_xreg) (lnot val)))
    (let (
        (dst XReg (xreg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.Seqz dst val_reg))))
    (InstOutput.OutputReg dst)))

;;;; Rules for cast operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; Cast指令的to字段指定目标类型，结果类型应该与目标类型匹配
;; 支持的类型转换:
;; - bool -> i32
;; - i32 <-> i64
;; - i32 <-> f32, i32 <-> f64
;; - i64 <-> f32, i64 <-> f64  
;; - f32 <-> f64

;; Cast to Int32
(rule 0 (lower (has_type (ty_i32 ty) (cast val Type.Int32)))
    (let (
        (dst XReg (x_operand val)))  ;; i64->i32截断，直接使用寄存器
    (InstOutput.OutputReg dst)))

;; Cast to Int64
(rule 1 (lower (has_type (ty_i64 ty) (cast val Type.Int64)))
    (let (
        (dst XReg (xreg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.Sextw dst val_reg))))  ;; i32->i64 符号扩展
    (InstOutput.OutputReg dst)))

;; Cast to Float32
(rule 2 (lower (has_type (ty_f32 ty) (cast val @ (value_type (ty_i32 val_ty)) Type.Float32)))
    (let (
        (dst FReg (freg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.FcvtSW dst val_reg))))  ;; i32->f32
    (InstOutput.OutputReg dst)))

(rule 3 (lower (has_type (ty_f32 ty) (cast val @ (value_type (ty_i64 val_ty)) Type.Float32)))
    (let (
        (dst FReg (freg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.FcvtSL dst val_reg))))  ;; i64->f32
    (InstOutput.OutputReg dst)))

(rule 4 (lower (has_type (ty_f32 ty) (cast val @ (value_type (ty_f64 val_ty)) Type.Float32)))
    (let (
        (dst FReg (freg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FcvtSD dst val_reg))))  ;; f64->f32
    (InstOutput.OutputReg dst)))

;; Cast to Float64
(rule 5 (lower (has_type (ty_f64 ty) (cast val @ (value_type (ty_i32 val_ty)) Type.Float64)))
    (let (
        (dst FReg (freg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.FcvtDW dst val_reg))))  ;; i32->f64
    (InstOutput.OutputReg dst)))

(rule 6 (lower (has_type (ty_f64 ty) (cast val @ (value_type (ty_i64 val_ty)) Type.Float64)))
    (let (
        (dst FReg (freg_new))
        (val_reg XReg (x_operand val))
        (_ Unit (emit (MInst.FcvtDL dst val_reg))))  ;; i64->f64
    (InstOutput.OutputReg dst)))

(rule 7 (lower (has_type (ty_f64 ty) (cast val @ (value_type (ty_f32 val_ty)) Type.Float64)))
    (let (
        (dst FReg (freg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FcvtDS dst val_reg))))  ;; f32->f64
    (InstOutput.OutputReg dst)))

;; Cast from Float32 to Int32
(rule 8 (lower (has_type (ty_i32 ty) (cast val @ (value_type (ty_f32 val_ty)) Type.Int32)))
    (let (
        (dst XReg (xreg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FcvtWS dst val_reg))))  ;; f32->i32
    (InstOutput.OutputReg dst)))

;; Cast from Float64 to Int32
(rule 9 (lower (has_type (ty_i32 ty) (cast val @ (value_type (ty_f64 val_ty)) Type.Int32)))
    (let (
        (dst XReg (xreg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FcvtWD dst val_reg))))  ;; f64->i32
    (InstOutput.OutputReg dst)))

;; Cast from Float32 to Int64
(rule 10 (lower (has_type (ty_i64 ty) (cast val @ (value_type (ty_f32 val_ty)) Type.Int64)))
    (let (
        (dst XReg (xreg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FcvtLS dst val_reg))))  ;; f32->i64
    (InstOutput.OutputReg dst)))

;; Cast from Float64 to Int64
(rule 11 (lower (has_type (ty_i64 ty) (cast val @ (value_type (ty_f64 val_ty)) Type.Int64)))
    (let (
        (dst XReg (xreg_new))
        (val_reg FReg (f_operand val))
        (_ Unit (emit (MInst.FcvtLD dst val_reg))))  ;; f64->i64
    (InstOutput.OutputReg dst)))

;; Cast Bool to Int32
;; bool值在寄存器中已经是0或1，直接使用
(rule 12 (lower (has_type (ty_i32 ty) (cast val @ (value_type (ty_bool val_ty)) Type.Int32)))
    (let (
        (dst XReg (xreg_new))
        (src XReg (x_operand val))
        (_ Unit (emit (MInst.Mv dst src))))
    (InstOutput.OutputReg dst)))

;; Cast Int32 to Bool  
;; 任何非零值都被认为是true，需要使用 snez 指令
(rule 13 (lower (has_type (ty_bool ty) (cast val @ (value_type (ty_i32 val_ty)) Type.Bool)))
    (let (
        (dst XReg (xreg_new))
        (src XReg (x_operand val))
        (_ Unit (emit (MInst.Snez dst src))))  ;; snez: set if not equal to zero
    (InstOutput.OutputReg dst)))

;;;; Rules for comparison operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 独立的比较指令，返回bool类型

;; Eq - 相等比较
(rule 14 (lower (has_type (ty_bool ty) (eq x y)))
    (let (
        (dst XReg (xreg_new))
        (lhs XReg (x_operand x))
        (rhs XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Xor tmp lhs rhs)))  ;; xor产生差异
        (_ Unit (emit (MInst.Seqz dst tmp))))     ;; seqz检查是否为0
    (InstOutput.OutputReg dst)))

;; Ne - 不相等比较  
(rule 15 (lower (has_type (ty_bool ty) (ne x y)))
    (let (
        (dst XReg (xreg_new))
        (lhs XReg (x_operand x))
        (rhs XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Xor tmp lhs rhs)))  ;; xor产生差异
        (_ Unit (emit (MInst.Snez dst tmp))))    ;; snez检查是否非0
    (InstOutput.OutputReg dst)))

;; Lt - 小于比较（有符号）
(rule 16 (lower (has_type (ty_bool ty) (lt x y)))
    (let (
        (dst XReg (xreg_new))
        (lhs XReg (x_operand x))
        (rhs XReg (x_operand y))
        (_ Unit (emit (MInst.Slt dst lhs rhs))))  ;; slt: set if less than (signed)
    (InstOutput.OutputReg dst)))

;; Le - 小于等于（有符号）
(rule 17 (lower (has_type (ty_bool ty) (le x y)))
    (let (
        (dst XReg (xreg_new))
        (lhs XReg (x_operand x))
        (rhs XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Slt tmp rhs lhs)))   ;; slt反向比较: y < x
        (_ Unit (emit (MInst.Xori dst tmp 1))))   ;; 取反得到 x <= y
    (InstOutput.OutputReg dst)))

;; Gt - 大于（有符号）
(rule 18 (lower (has_type (ty_bool ty) (gt x y)))
    (let (
        (dst XReg (xreg_new))
        (lhs XReg (x_operand x))
        (rhs XReg (x_operand y))
        (_ Unit (emit (MInst.Slt dst rhs lhs))))  ;; slt反向: y < x 等价于 x > y
    (InstOutput.OutputReg dst)))

;; Ge - 大于等于（有符号）
(rule 19 (lower (has_type (ty_bool ty) (ge x y)))
    (let (
        (dst XReg (xreg_new))
        (lhs XReg (x_operand x))
        (rhs XReg (x_operand y))
        (tmp XReg (xreg_new))
        (_ Unit (emit (MInst.Slt tmp lhs rhs)))   ;; slt: x < y
        (_ Unit (emit (MInst.Xori dst tmp 1))))   ;; 取反得到 x >= y
    (InstOutput.OutputReg dst)))


;;;; Rules for memory operations ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; stack_addr - 获取栈槽地址
(rule (lower (stack_addr slot))
    (let (
        (dst XReg (xreg_new))
        (slot_id SlotId (stackslot_to_slotid slot))
        (kind SlotKindDisc (stackslot_to_kind slot))
        (_ Unit (emit (MInst.AddrSlot dst slot_id kind))))
    (InstOutput.OutputReg dst)))

;; global_addr - 获取全局变量地址
(rule (lower (global_addr global))
    (let (
        (dst XReg (xreg_new))
        (label Label (global_to_label global))
        (_ Unit (emit (MInst.La dst label))))
    (InstOutput.OutputReg dst)))

;; load - 内存加载
(rule 0 (lower (has_type (ty_i32 ty) (load addr offset _ token)))
    (let (
        (dst XReg (xreg_new))
        (addr_reg XReg (x_operand addr))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Lw dst addr_reg imm12))))
    (InstOutput.OutputReg dst)))

(rule 1 (lower (has_type (ty_i64 ty) (load addr offset _ token)))
    (let (
        (dst XReg (xreg_new))
        (addr_reg XReg (x_operand addr))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Ld dst addr_reg imm12))))
    (InstOutput.OutputReg dst)))

(rule 2 (lower (has_type (ty_f32 ty) (load addr offset _ token)))
    (let (
        (dst FReg (freg_new))
        (addr_reg XReg (x_operand addr))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Flw dst addr_reg imm12))))
    (InstOutput.OutputReg dst)))

(rule 3 (lower (has_type (ty_f64 ty) (load addr offset _ token)))
    (let (
        (dst FReg (freg_new))
        (addr_reg XReg (x_operand addr))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Fld dst addr_reg imm12))))
    (InstOutput.OutputReg dst)))

;; store - 内存存储
(rule 0 (lower (store addr offset value (ty_i32 ty) token))
    (let (
        (addr_reg XReg (x_operand addr))
        (val_reg XReg (x_operand value))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Sw val_reg addr_reg imm12))))
    (InstOutput.OutputNone)))

(rule 1 (lower (store addr offset value (ty_i64 ty) token))
    (let (
        (addr_reg XReg (x_operand addr))
        (val_reg XReg (x_operand value))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Sd val_reg addr_reg imm12))))
    (InstOutput.OutputNone)))

(rule 2 (lower (store addr offset value (ty_f32 ty) token))
    (let (
        (addr_reg XReg (x_operand addr))
        (val_reg FReg (f_operand value))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Fsw val_reg addr_reg imm12))))
    (InstOutput.OutputNone)))

(rule 3 (lower (store addr offset value (ty_f64 ty) token))
    (let (
        (addr_reg XReg (x_operand addr))
        (val_reg FReg (f_operand value))
        (imm12 Imm12 (imm12_from_offset offset))
        (_ Unit (emit (MInst.Fsd val_reg addr_reg imm12))))
    (InstOutput.OutputNone)))

