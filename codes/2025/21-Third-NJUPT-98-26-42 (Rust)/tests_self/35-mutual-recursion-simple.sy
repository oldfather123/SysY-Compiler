// 测试相互递归的SCC检测

int is_even(int n);

int is_odd(int n) {
    if (n == 0) {
        return 0;
    }
    return is_even(n - 1);
}

int is_even(int n) {
    if (n == 0) {
        return 1;
    }
    return is_odd(n - 1);
}

// 三个函数相互递归
int f1(int n);
int f2(int n);
int f3(int n);

int f1(int n) {
    if (n <= 0) return 1;
    return f2(n - 1) + f3(n - 2);
}

int f2(int n) {
    if (n <= 0) return 2;
    return f3(n - 1) + f1(n - 2);
}

int f3(int n) {
    if (n <= 0) return 3;
    return f1(n - 1) + f2(n - 2);
}

int main() {
    int even = is_even(10);
    int odd = is_odd(10);
    int result = f1(5);
    return even + odd + result;
}