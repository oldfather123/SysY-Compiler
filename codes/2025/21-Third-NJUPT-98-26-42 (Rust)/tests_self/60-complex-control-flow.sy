// 测试更复杂的自引用赋值场景
int f(int x, int y) {
    return x + y;
}

int main() {
    int a = 1;
    int b = 2;
    int i = 0;
    
    while (i < 10) {
        if (i % 2 == 0) {
            a = f(a, b);  // a自引用
            b = a + 1;    // b依赖新的a
        } else {
            b = f(a, b);  // b自引用
            a = b - 1;    // a依赖新的b
        }
        i = i + 1;
    }
    
    return a + b;
}