// 测试函数调用中的变量别名问题 - 循环中的复杂情况
int swap(int a, int b) {
    return a + b;
}

int main() {
    int dad = 1;
    int son = 2;
    
    // 循环中的别名情况，模拟59_sort_test5.sy中的问题
    while (dad > 0) {
        dad = swap(dad, son);  // 这里dad既是参数又是返回值的接收者
        son = dad * 2;
        if (dad > 10) {
            break;
        }
    }
    
    return dad;
}