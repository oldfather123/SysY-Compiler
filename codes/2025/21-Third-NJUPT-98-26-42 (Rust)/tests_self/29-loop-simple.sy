// 简单循环测试
int main() {
    int sum = 0;
    int i = 0;
    
    // 简单 while 循环
    while (i < 10) {
        sum = sum + i;
        i = i + 1;
    }
    
    // 嵌套循环
    int j = 0;
    while (j < 5) {
        int k = 0;
        while (k < 3) {
            sum = sum + j * k;
            k = k + 1;
        }
        j = j + 1;
    }
    
    return sum;
}