// 测试一元运算符: +, -, !
// 一元正号运算符测试
// 测试不同情况下的一元正号运算符

int main() {
    int a, b, c;
    
    // 基本一元正号测试
    a = +42;
    putint(a);  // 应该输出 42
    putch(10);  // 换行
    
    // 变量上的一元正号
    b = 25;
    c = +b;
    putint(c);  // 应该输出 25
    putch(10);  // 换行
    
    // 负数上的一元正号
    a = +(-15);
    putint(a);  // 应该输出 -15
    putch(10);  // 换行
    
    // 表达式上的一元正号
    b = 10;
    c = +(b + 5);
    putint(c);  // 应该输出 15
    putch(10);  // 换行
    
    // 连续一元正号
    a = +++++7;
    putint(a);  // 应该输出 7
    putch(10);  // 换行
    
    return 0;
}
// 负号测试
// 一元负号运算符测试
// 测试不同情况下的一元负号运算符

int main() {
    int a, b, c;
    
    // 基本一元负号测试
    a = -42;
    putint(a);  // 应该输出 -42
    putch(10);  // 换行
    
    // 变量上的一元负号
    b = 25;
    c = -b;
    putint(c);  // 应该输出 -25
    putch(10);  // 换行
    
    // 负数上的一元负号（双重否定）
    a = -(-15);
    putint(a);  // 应该输出 15
    putch(10);  // 换行
    
    // 表达式上的一元负号
    b = 10;
    c = -(b + 5);
    putint(c);  // 应该输出 -15
    putch(10);  // 换行
    
    // 连续一元负号
    a = -----7;  // 奇数个负号，结果为负
    putint(a);  // 应该输出 -7
    putch(10);  // 换行
    
    // 偶数个一元负号
    b = ----8;   // 偶数个负号，结果为正
    putint(b);  // 应该输出 8
    putch(10);  // 换行
    
    // 零的一元负号
    c = -0;
    putint(c);  // 应该输出 0
    putch(10);  // 换行
    
    return 0;
}
// 逻辑非测试
// 逻辑非运算符测试
// 测试不同情况下的逻辑非运算符

int main() {
    int a, b, c;
    
    // 基本逻辑非测试
    a = !0;      // !0 应该是 1
    putint(a);   // 应该输出 1
    putch(10);   // 换行
    
    b = !1;      // !1 应该是 0
    putint(b);   // 应该输出 0
    putch(10);   // 换行
    
    // 非零值的逻辑非
    c = !42;     // !42 应该是 0（任何非零值都是真）
    putint(c);   // 应该输出 0
    putch(10);   // 换行
    
    // 负数的逻辑非
    a = !(-5);   // !(-5) 应该是 0
    putint(a);   // 应该输出 0
    putch(10);   // 换行
    
    // 变量的逻辑非
    b = 0;
    c = !b;      // !0 应该是 1
    putint(c);   // 应该输出 1
    putch(10);   // 换行
    
    // 连续逻辑非
    a = !!1;     // !!1 应该是 1
    putint(a);   // 应该输出 1
    putch(10);   // 换行
    
    b = !!!1;    // !!!1 应该是 0
    putint(b);   // 应该输出 0
    putch(10);   // 换行
    
    c = !!!!1;   // !!!!1 应该是 1
    putint(c);   // 应该输出 1
    putch(10);   // 换行
    
    // 表达式的逻辑非
    a = 5;
    b = 3;
    c = !(a + b);  // !(5+3) = !8 = 0
    putint(c);   // 应该输出 0
    putch(10);   // 换行
    
    return 0;
}
