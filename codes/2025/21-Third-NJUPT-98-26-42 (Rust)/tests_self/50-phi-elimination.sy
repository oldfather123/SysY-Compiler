int main() {
    int a = 1;
    int b = 100;
    int c = 1000; // 一个固定的值，用于穿透
    
    int i = 0;
    while (i < 2) {
        // 在钻石型分支之前，a 被修改
        a = a + 10; 

        if (a > 20) {
            // 分支 1: 只修改 b
            b = b + 50;
        } else {
            // 分支 2: 不修改 b
            // 此时 b 的值 "穿透" 了这个分支
        }
        
        // ---- 在这里的合并点 (Merge Point) ----
        // 您的 SSABuilder 会为 a, b, c 都创建临时的块参数 (Phi)
        // a 的 Phi: phi(a_from_branch1, a_from_branch2)。因为两边 a 的值都一样，这个Phi是冗余的。
        // b 的 Phi: phi(b_new, b_old)。因为两边 b 的值不同，这个Phi是必需的。
        // c 的 Phi: phi(c_from_branch1, c_from_branch2)。因为两边 c 的值都一样，这个Phi是冗余的。
        
        // 使用合并后的值，这会强制 use_var 触发 Phi 的创建
        a = a + b;
        c = c + 1; // 让 c 也不是完全不变，但其在钻石分支中是穿透的

        i = i + 1;
    }

    // 循环结束
    // 最终返回一个依赖于所有计算结果的值
    return a + b + c;
}