// 测试CallGraph的复杂调用关系

int factorial(int n) {
    if (n <= 1) {
        return 1;
    }
    return n * factorial(n - 1);  // 递归调用
}

int fib(int n) {
    if (n <= 1) {
        return n;
    }
    return fib(n - 1) + fib(n - 2);  // 递归调用
}

int helper(int x) {
    return x * 2;
}

int compute(int a, int b) {
    int x = helper(a);  // 调用helper
    int y = helper(b);  // 调用helper
    return x + y;
}

int unused_func() {
    return 42;  // 没有被调用
}

int main() {
    int a = factorial(5);   // 调用factorial
    int b = fib(6);        // 调用fib
    int c = compute(a, b); // 调用compute
    return c;
}