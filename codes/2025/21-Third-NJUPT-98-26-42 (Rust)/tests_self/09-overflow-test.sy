void overflow_test() {

    int var1 = 0, var2 = 1, var3 = 2, var4 = 3, var5 = 4;
    int var6 = 5, var7 = 6, var8 = 7, var9 = 8, var10 = 9;
    int var11 = 10, var12 = 11, var13 = 12, var14 = 13, var15 = 14;
    int var16 = 15, var17 = 16, var18 = 17, var19 = 18, var20 = 19;
    int var21 = 20, var22 = 21, var23 = 22, var24 = 23, var25 = 24;
    int var26 = 25;

   
    while (var1 < 100000) {
        var1 = var1 + var2 - var3 + var4 * var5;
        var2 = var2 * var6 - var7 + var8 * var9;
        var3 = var3 + var10 * var11 - var12 + var13;
        var4 = var4 - var14 + var15 * var16;
        var5 = var5 * var17 - var18 + var19;

        var6 = var6 + var20 - var21 + var22 * var23;
        var7 = var7 - var24 + var25 * var26;
        var8 = var8 + var5 * var17 - var18 + var19 + var5 * var17 - var18 + var19 - var24 + var25 * var26;
        var8 = var8 + var5 * var17 - var18 + var19 + var5 * var17 - var18 + var19 - var24 + var25 * var26;
        var9 = var9 *  - var1 + var2;

        var10 = var10 + var11 * var12 - var13;
        var11 = var11 + var14 - var15 * var16;
        var12 = var12 * var17 - var18 + var19;
        var13 = var13 + var20 - var21 * var22;

        // 确保栈占用
        var14 = var14 + var23 - var24 * var25;
        var15 = var15 * var26 ;
        var16 = var16 +  +var8 + var5 * var17 - var18 + var19 + var5 * var17 - var18 + var19 - var24 + var25 * var26+ var1;
        var17 = var17 + var2 * var3 - var4;

        var18 = var18 + var5 - var6 * var7;
        var19 = var19 * var8 - var9 + var10;
        var20 = var20 + var11 * var12 - var13;

   
        var21 = var21 + var14 - var15 * var16;
        var22 = var22 * var17 - var18 + var19;
        var23 = var23 + var20 * var21 - var22;

        var24 = var24 + var23 - var24 * var25;
        var25 = var25 * var26 ;

        var26 = var26 * var1;
 

        var1=var1+1; 
    }
}

int main() {
    overflow_test();  
    return 0;
}