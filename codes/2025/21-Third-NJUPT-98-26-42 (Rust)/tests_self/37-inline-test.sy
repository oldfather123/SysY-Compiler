// 简单的内联测试 - 不涉及递归

// 简单的加法函数
int add(int a, int b) {
    return a + b;
}

// 简单的乘法函数
int mul(int x, int y) {
    return x * y;
}

// 组合函数 - 应该内联 add 和 mul
int compute(int p, int q, int r) {
    int sum = add(p, q);      // 应该被内联
    int product = mul(sum, r); // 应该被内联
    return product;
}

// 主函数
int main() {
    int result = compute(1, 2, 3); // compute 也应该被内联
    return result; // 应该返回 (1+2)*3 = 9
}