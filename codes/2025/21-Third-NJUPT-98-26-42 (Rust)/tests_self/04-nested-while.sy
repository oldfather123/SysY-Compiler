int test_nested_while() {
    int i = 0, j = 1, k = 2;
    
    while (i < 5) {
        if (j > 0) {
            i = i + 1;
            j = j - 1;
        } else {
            i = i + 2;  
            k = k + 1;
        }
        
        // 内层while循环
        while (k < 10) {
            k = k + 1;
            i = i + 1;
        }
    }
    
    return i + j + k;
}

int main() {
    return test_nested_while();
}