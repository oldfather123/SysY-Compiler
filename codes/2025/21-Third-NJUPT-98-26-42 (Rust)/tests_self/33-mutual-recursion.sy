// 测试相互递归的情况

// 相互递归的两个函数
int even(int n);

int odd(int n) {
    if (n == 0) {
        return 0;
    }
    return even(n - 1);
}

int even(int n) {
    if (n == 0) {
        return 1;
    }
    return odd(n - 1);
}

// 另一组相互递归（三个函数）
int f1(int x);
int f2(int x);
int f3(int x);

int f1(int x) {
    if (x <= 0) return 1;
    return f2(x - 1) + f3(x - 2);
}

int f2(int x) {
    if (x <= 0) return 2;
    return f1(x - 1) * f3(x - 1);
}

int f3(int x) {
    if (x <= 0) return 3;
    return f1(x - 2) + f2(x - 1);
}

// 辅助函数
int helper1(int x) {
    return x + 1;
}

int helper2(int x) {
    return helper1(x) * 2;
}

// 使用以上函数的函数
int use_all(int n) {
    int a = even(n);
    int b = f1(n);
    int c = helper2(n);
    return a + b + c;
}

int main() {
    return use_all(5);
}