{
    "name": "GeeCeeCee dev container",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "clangd.checkUpdates": true,
                "clangd.path": "/usr/lib/llvm-18/bin/clangd",
                "clangd.detectExtensionConflicts": true,
                "clangd.fallbackFlags": [],
                "clangd.arguments": [
                    "--background-index",
                    "-j=12",
                    "--all-scopes-completion",
                    "--completion-style=detailed",
                    "--header-insertion=iwyu",
                    "--pch-storage=memory",
                    "--cross-file-rename",
                    "--enable-config",
                    // clang-format style to apply by default when no .clang-format file is found
                    "--fallback-style=WebKit",
                    "--pretty",
                    "--clang-tidy",
                    "--query-driver=clang++"
                ],
                "explorer.confirmDelete": false,
                "editor.formatOnSave": true
            },
            "extensions": [
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools",
                "vadimcn.vscode-lldb"
            ]
        }
    },
    "remoteEnv": {
        "PATH": "/usr/lib/llvm-18/bin:${containerEnv:PATH}",
        "CC": "clang-18",
        "CXX": "clang++-18",
        "LLVM_CONFIG": "/usr/lib/llvm-18/bin/llvm-config"
    },
    "remoteUser": "vscode",
    "postCreateCommand": "git config --global --add safe.directory $(pwd)"
}
